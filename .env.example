# Deployment router
DOMAIN=your.domain.com
ACME_EMAIL=you@example.com

# App secrets
NUXT_SESSION_PASSWORD=

# Supabase
NUXT_SUPABASE_URL=https://your-project.supabase.co
NUXT_SUPABASE_KEY=your-anon-key
NUXT_SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
NUXT_STRIPE_SECRET_KEY=sk_live_or_test_xxx
NUXT_STRIPE_ALLOWED_PRICE_IDS=price_xxx
NUXT_STRIPE_DEFAULT_PRICE_ID=price_xxx

# Checkout defaults
NUXT_STRIPE_DEFAULT_EVENT_ID=1
NUXT_STRIPE_DEFAULT_ORDER_ITEM_ID=1
